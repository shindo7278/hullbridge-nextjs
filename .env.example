# ============================================================
# انسخي الملف ده باسم .env قبل التشغيل، واملي القيم الحقيقية
# ============================================================

# رابط قاعدة بيانات Postgres — من Supabase: Settings → Database → Connection String
DATABASE_URL="postgresql://user:password@host:5432/hullbridge_dental"

# سر تشفير جلسة الأدمن — ولّديه بالأمر: openssl rand -base64 32
ADMIN_JWT_SECRET="replace-with-a-long-random-string"

# مفتاح Resend لإرسال إيميلات الإشعار (اختياري للتشغيل المحلي الأول)
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"

# رابط الموقع (يُستخدم في الـ Schema وروابط الإيميل)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# بيانات أول حساب أدمن (تُستخدم فقط مرة واحدة عند تشغيل seed:admin)
SEED_ADMIN_EMAIL="admin@hullbridgedentalclinic.co.uk"
SEED_ADMIN_PASSWORD="AaMm778899$$"
