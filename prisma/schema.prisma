generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ClinicSettings {
  id                   Int      @id @default(1)
  legalName            String   @default("Hullbridge Dental Clinic")
  phone                String   @default("01702 231067")
  email                String   @default("info@hullbridgedentalclinic.co.uk")
  whatsapp             String   @default("01702 231067")
  addressLine1         String   @default("130 Ferry Road")
  addressLine2         String?  @default("Hullbridge")
  city                 String   @default("Hockley")
  postcode             String   @default("SS5 6EU")
  county               String   @default("Essex")
  country              String   @default("United Kingdom")
  latitude             Float?
  longitude            Float?
  facebookUrl          String?
  instagramUrl         String?
  googleBusinessUrl    String?
  googlePlaceId        String?
  heroVideoUrl         String?
  heroFallbackImageUrl String?
  updatedAt            DateTime @updatedAt
}

model OpeningHour {
  id        Int      @id @default(autoincrement())
  dayOfWeek Int
  isOpen    Boolean  @default(true)
  startTime String
  endTime   String
  note      String?
  updatedAt DateTime @updatedAt
}

model ScheduleException {
  id        Int      @id @default(autoincrement())
  date      DateTime @db.Date
  isOpen    Boolean  @default(false)
  startTime String?
  endTime   String?
  reason    String?
  createdAt DateTime @default(now())
}

model Booking {
  id           String        @id @default(cuid())
  date         DateTime      @db.Date
  startTime    String
  endTime      String
  status       BookingStatus @default(PENDING)
  source       BookingSource @default(ONLINE)
  patientName  String
  patientPhone String
  patientEmail String
  patientAge   Int
  serviceId    String?
  notes        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  service      Service?      @relation(fields: [serviceId], references: [id])

  @@unique([date, startTime], name: "uniqueSlot")
  @@index([date])
}

model Service {
  id              String       @id @default(cuid())
  slug            String       @unique
  name            String
  category        String
  shortSummary    String
  bodyContent     String
  metaTitle       String?
  metaDescription String?
  durationMinutes Int          @default(30)
  priceFrom       Decimal?     @db.Decimal(10, 2)
  isPublished     Boolean      @default(true)
  sortOrder       Int          @default(0)
  updatedAt       DateTime     @updatedAt
  createdAt       DateTime     @default(now())
  linkedFromPosts BlogPost[]
  bookings        Booking[]
  prices          PriceItem[]
  faqs            ServiceFaq[]
}

model ServiceFaq {
  id        String  @id @default(cuid())
  serviceId String
  question  String
  answer    String
  sortOrder Int     @default(0)
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
}

model GeneralFaq {
  id          String  @id @default(cuid())
  question    String
  answer      String
  category    String?
  sortOrder   Int     @default(0)
  isPublished Boolean @default(true)
}

model PriceCategory {
  id        String      @id @default(cuid())
  name      String
  sortOrder Int         @default(0)
  items     PriceItem[]
}

model PriceItem {
  id          String        @id @default(cuid())
  categoryId  String
  serviceId   String?
  name        String
  price       Decimal       @db.Decimal(10, 2)
  priceSuffix String?
  sortOrder   Int           @default(0)
  category    PriceCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  service     Service?      @relation(fields: [serviceId], references: [id])
}

model BlogPost {
  id              String     @id @default(cuid())
  slug            String     @unique
  title           String
  excerpt         String
  bodyContent     String
  coverImageUrl   String?
  metaTitle       String?
  metaDescription String?
  authorName      String     @default("Hullbridge Dental Clinic")
  isPublished     Boolean    @default(false)
  publishedAt     DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  linkedPostId    String?
  linkedServiceId String?
  secondImageUrl  String?
  linkedPost      BlogPost?  @relation("PostToPost", fields: [linkedPostId], references: [id])
  linkedFromPosts BlogPost[] @relation("PostToPost")
  linkedService   Service?   @relation(fields: [linkedServiceId], references: [id])
}

model Review {
  id          String   @id @default(cuid())
  authorName  String
  rating      Int
  text        String
  reviewDate  DateTime
  source      String   @default("Google")
  isPublished Boolean  @default(true)
  sortOrder   Int      @default(0)
}

model ContactMessage {
  id          String        @id @default(cuid())
  name        String
  email       String
  phone       String?
  message     String
  status      MessageStatus @default(NEW)
  emailSentOk Boolean       @default(false)
  createdAt   DateTime      @default(now())
}

model AdminUser {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String
  role         AdminRole @default(STAFF)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum BookingSource {
  ONLINE
  ADMIN
}

enum MessageStatus {
  NEW
  READ
  REPLIED
}

enum AdminRole {
  OWNER
  STAFF
}
